#
# Copy to .env and fill values (do NOT commit .env).
#

# If you're using Groq (OpenAI-compatible), set:
GROQ_API_KEY=

# If you're using OpenAI directly, set:
OPENAI_API_KEY=

# Optional: override base URL for any OpenAI-compatible provider.
# - Groq: https://api.groq.com/openai/v1
# - OpenAI: https://api.openai.com/v1
OPENAI_BASE_URL=

# Optional: default model (UI lets you override)
LLM_MODEL=

# Optional search providers (pick one)
TAVILY_API_KEY=
SERPER_API_KEY=
